config ZMK_KEY_LAYER_DEFER
    bool "Defer non-combo key dispatch for layer detection"
    default n

config ZMK_KEY_LAYER_DEFER_MS
    int "Layer detection window (ms)"
    default 50
    depends on ZMK_KEY_LAYER_DEFER

config ZMK_KEY_LAYER_DEFER_SLOTS
    int "Maximum concurrently deferred keys"
    default 8
    depends on ZMK_KEY_LAYER_DEFER
